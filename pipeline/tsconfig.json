{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "outDir": "dist",
    "paths": {
      "recordly-project-format": ["../packages/recordly-project-format/src/index.ts"]
    }
  },
  "include": ["core", "cli.ts"],
  "exclude": ["dist", "node_modules"]
}
